DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportscalendar
REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_SECRET=change-me-in-development

# TheSportsDB API key. The value "3" is the public test key documented by
# TheSportsDB and is fine for development. For production use a real key.
THESPORTSDB_API_KEY=3

# Set to "false" to disable the periodic data ingestion cron jobs (useful in tests).
SCHEDULER_ENABLED=true
# Set to "false" to skip the initial sync that runs at server startup.
SCHEDULER_RUN_ON_START=true
